{
  "name": "pnk-forever-v1",
  "version": "1.0.0",
  "description": "P&K Forever - Modern reimagining with Narrat",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build && npm run copy:v0",
    "copy:v0": "cp -r ../v0-original-text-engine dist/v0-original-text-engine && echo 'Copied v0 to dist/v0-original-text-engine'",
    "preview": "vite preview --host",
    "generate:assets": "node scripts/generate-assets.mjs",
    "generate:assets:force": "node scripts/generate-assets.mjs --force"
  },
  "dependencies": {
    "narrat": "^3.12.4",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-narrat": "^4.1.12"
  }
}
