{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pnk-forever/content/schema/scene.schema.json",
  "title": "Scene",
  "description": "An environment / screen. Backdrop + ambient audio + display name.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "background"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "displayName": {
      "type": "string"
    },
    "background": {
      "type": "string",
      "description": "Asset path relative to content/assets/backgrounds/."
    },
    "music": {
      "type": ["string", "null"],
      "description": "Looping bgm asset path, or null for silence."
    },
    "ambientSfx": {
      "type": ["string", "null"],
      "description": "Looping ambient sound effect, or null."
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
